{
  "name": "@indobase/js",
  "version": "1.0.0",
  "description": "Official Indobase JavaScript/TypeScript SDK",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "indobase": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "@indobase/indobase-js": "*"
  },
  "workspaces": [
    "packages/core/*"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Indobase/Indobase-js.git",
    "directory": "."
  },
  "keywords": [
    "indobase",
    "sdk",
    "database",
    "postgresql",
    "realtime",
    "auth",
    "storage",
    "functions"
  ],
  "author": "Indobase",
  "bugs": "https://github.com/Indobase/Indobase-js/issues",
  "homepage": "https://github.com/Indobase/Indobase-js"
}
